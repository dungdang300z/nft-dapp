# =========================================
# Cấu hình môi trường cho NFT Studio DApp
# Copy file này thành .env.local và điền vào
# =========================================

# Địa chỉ smart contract sau khi deploy lên Sepolia
REACT_APP_CONTRACT_ADDRESS=0xYourContractAddressHere

# Pinata IPFS (tùy chọn - để upload ảnh lên IPFS)
# Đăng ký miễn phí tại: https://pinata.cloud
REACT_APP_PINATA_API_KEY=
REACT_APP_PINATA_SECRET_KEY=
